#!/bin/sh
set -eu

APP_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

if command -v python3 >/dev/null 2>&1; then
    FRONTEND="$APP_DIR/gurk-gtk-frontend.py"
    if [ -f "$FRONTEND" ] && python3 -c 'import gi; gi.require_version("Gtk", "3.0"); gi.require_version("Vte", "2.91"); from gi.repository import Gtk, Vte' >/dev/null 2>&1; then
        exec python3 "$FRONTEND" "$APP_DIR/gurk" "$@"
    fi
fi

if command -v lomiri-terminal-app >/dev/null 2>&1; then
    exec lomiri-terminal-app -e "$APP_DIR/gurk" "$@"
fi

if command -v ubuntu-terminal-app >/dev/null 2>&1; then
    exec ubuntu-terminal-app -e "$APP_DIR/gurk" "$@"
fi

exec "$APP_DIR/gurk" "$@"
